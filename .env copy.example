# Copy this file to .env and fill in your values
# For local development, defaults are fine — only SECRET_KEY matters for production.

# Application
APP_NAME=CSP Analyzer
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Database
# Local SQLite (default):
DATABASE_URL=sqlite:///./csp_analyzer.db
# PostgreSQL for cloud (uncomment and set):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Security — REQUIRED for production: set to a long random string
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Session lifetime in seconds (default: 7 days)
SESSION_MAX_AGE=604800

# Default admin credentials — used only on first run when no users exist
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=admin123
DEFAULT_ADMIN_EMAIL=admin@localhost

# Background price refresh interval in seconds
PRICE_REFRESH_INTERVAL=300
